{
  "suite_name": "generalization_gold_v1",
  "description": "Unseen-paper RAG generalization benchmark. It avoids the original demo/sample papers and checks method, result, dataset, efficiency, cross-document comparison, and unsupported-claim refusal behavior.",
  "cases": [
    {
      "id": "efficientnet_method_001",
      "case_type": "method",
      "difficulty": "medium",
      "tags": ["unseen", "method", "model_scaling"],
      "question": "How does the EfficientNet paper describe its compound scaling method?",
      "expected_document": "efficientnet.pdf",
      "gold_evidence": [
        {
          "document": "efficientnet.pdf",
          "text_contains": ["compound coefficient", "uniformly scales network width, depth, and resolution"]
        },
        {
          "document": "efficientnet.pdf",
          "text_contains": ["balancing network depth, width, and resolution", "better performance"]
        }
      ],
      "expected_answer_points": ["compound coefficient", "depth", "width", "resolution"]
    },
    {
      "id": "efficientnet_result_002",
      "case_type": "result",
      "difficulty": "easy",
      "tags": ["unseen", "result", "benchmark"],
      "question": "What ImageNet result does EfficientNet-B7 report, and what efficiency comparison is claimed?",
      "expected_document": "efficientnet.pdf",
      "gold_evidence": [
        {
          "document": "efficientnet.pdf",
          "text_contains": ["EfficientNet-B7", "84.3% top-1 accuracy"]
        },
        {
          "document": "efficientnet.pdf",
          "text_contains": ["8.4x smaller", "6.1x faster"]
        }
      ],
      "expected_answer_points": ["84.3% top-1 accuracy", "8.4x smaller", "6.1x faster"]
    },
    {
      "id": "focal_loss_method_001",
      "case_type": "method",
      "difficulty": "medium",
      "tags": ["unseen", "method", "loss_function"],
      "question": "What problem does focal loss address in dense object detection, and how does it change cross entropy?",
      "expected_document": "focal-loss.pdf",
      "gold_evidence": [
        {
          "document": "focal-loss.pdf",
          "text_contains": ["class imbalance", "dense detectors"]
        },
        {
          "document": "focal-loss.pdf",
          "text_contains": ["down-weights the loss assigned to well-classified examples", "hard examples"]
        }
      ],
      "expected_answer_points": ["class imbalance", "down-weights", "well-classified examples", "hard examples"]
    },
    {
      "id": "focal_loss_result_002",
      "case_type": "result",
      "difficulty": "easy",
      "tags": ["unseen", "result", "object_detection"],
