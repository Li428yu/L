        },
        {
          "document": "focal-loss.pdf",
          "text_contains": ["surpass the accuracy", "state-of-the-art two-stage detectors"]
        }
      ],
      "expected_answer_points": ["RetinaNet", "one-stage detector", "surpass the accuracy", "two-stage detectors"]
    },
    {
