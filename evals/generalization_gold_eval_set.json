    {
      "id": "cross_efficiency_compare_001",
      "case_type": "compare",
      "difficulty": "hard",
      "tags": ["unseen", "multi_document", "efficiency"],
      "question": "Compare how EfficientNet and LoRA pursue efficiency. Use evidence from both papers.",
      "expected_documents": ["efficientnet.pdf", "lora.pdf"],
      "required_document_count": 2,
      "gold_evidence": [
        {
          "document": "efficientnet.pdf",
          "text_contains": ["compound coefficient", "width, depth, and resolution"]
        },
        {
          "document": "lora.pdf",
          "text_contains": ["freezing the pre-trained model weights", "rank decomposition matrices"]
