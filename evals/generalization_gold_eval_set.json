      "relation_keywords": ["compare", "efficiency"]
    },
    {
      "id": "unsupported_cross_domain_001",
      "case_type": "refusal",
      "difficulty": "easy",
      "tags": ["unseen", "refusal", "scope_control"],
      "question": "Does the focal loss paper prove that low-rank adaptation reduces trainable parameters in language model fine-tuning?",
      "expected_document": "focal-loss.pdf",
      "expected_refusal": true,
      "gold_evidence": [
        {
          "document": "focal-loss.pdf",
          "text_contains": ["dense object detector", "class imbalance"]
        }
      ],
      "expected_answer_points": ["cannot prove|not enough evidence|does not support", "object detection|class imbalance", "low-rank adaptation|language model"]
