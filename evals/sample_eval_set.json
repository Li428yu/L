{
  "suite_name": "paper_assistant_smoke",
  "description": "轻量健康检查 + 证据准确性守门：只确认问答链路、可点击引用、正确文档覆盖和关键证据词，不作为论文级质量分数。",
  "cases": [
    {
      "id": "single_doc_summary_with_evidence",
      "question": "请概括当前文档的核心内容，并给出证据。",
      "expected_keywords": ["核心", "内容", "证据"]
    },
    {
      "id": "method_or_design_with_evidence",
      "question": "这份文档的方法、设计或实现流程是什么？请基于证据回答。",
      "expected_keywords": ["方法", "设计", "流程", "实现"],
      "expected_evidence_keywords": ["方法", "设计", "流程", "实现", "步骤"]
    },
    {
      "id": "key_result_or_conclusion",
      "question": "文档给出了哪些关键结果或结论？请分别标注引用证据。",
      "expected_keywords": ["结果", "结论", "证据"],
      "expected_evidence_keywords": ["结果", "结论", "实验", "发现"]
    },
    {
      "id": "multi_doc_overview",
      "question": "如果当前有多份文档，请分别说明每份文档主要讲什么，再总结共同主题。",
      "expected_keywords": ["分别", "共同", "主题"],
      "required_document_count": 2
    },
    {
      "id": "evidence_detail_check",
      "question": "请选择一个最能支撑回答的原文证据，并说明它为什么相关。",
      "expected_keywords": ["证据", "相关", "支撑"]
    },
    {
      "id": "insufficient_evidence_refusal",
      "question": "请判断这些文档是否已经证明了一个与原文无关的结论：它能显著提高临床诊断准确率。",
      "expected_keywords": ["证据不足", "无法证明", "没有证据"],
      "expected_refusal": true
    }
  ]
}
