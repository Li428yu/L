API_KEY=your_embedding_provider_api_key_here
API_BASE_URL=https://your-embedding-provider-compatible-base-url
CHAT_API_KEY=your_deepseek_api_key_here
CHAT_API_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL_OPTIONS=deepseek-v4-flash,deepseek-v4-pro
EMBEDDING_MODEL_OPTIONS=text-embedding-3-small,text-embedding-3-large
DEFAULT_MODEL_PRESET=balanced
BALANCED_CHAT_MODEL=deepseek-v4-flash
BALANCED_EMBEDDING_MODEL=text-embedding-3-small
CAREFUL_CHAT_MODEL=deepseek-v4-pro
CAREFUL_EMBEDDING_MODEL=text-embedding-3-small
QUICK_CHAT_MODEL=deepseek-v4-flash
QUICK_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_TOP_K=5
MODEL_TIMEOUT_SECONDS=20
MODEL_MAX_RETRIES=1
FORCE_MODEL_ANSWER=false
DATA_DIR=data
VITE_API_BASE_URL=http://127.0.0.1:8000
